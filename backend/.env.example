DATABASE_URL=postgresql+asyncpg://hat01:hat01@postgres:5432/hat01
REDIS_URL=redis://redis:6379/0
MQTT_HOST=mosquitto
MQTT_PORT=1883
SEVIYE_SEYREK_UST=0.40
SEVIYE_ORTA_UST=0.70
REDIS_ARAC_TTL_SN=30
REDIS_HAT_TTL_SN=60
# Panelin çağıracağı origin'ler (virgülle ayrılmış). Prod'da kendi origin'inle değiştir.
CORS_IZINLI_ORIGINLER=http://localhost:3000,http://localhost:5173
# AI motoru (öneri + uyarı). "local" = SimpleAgent+Ollama, veri makineden ÇIKMAZ (varsayılan).
# "gemini" = bulut; sorular ve yoğunluk verisi Google'a GİDER, GEMINI_API_KEY zorunlu.
AI_MOTOR=local
OLLAMA_ADRESI=http://localhost:11434
# Yerel model (AI_MOTOR=local). ~9b sınıfı önerilir; küçük modeller JSON'u güvenilir üretmez.
YEREL_MODEL=alibayram/turkish-gemma-9b-v0.1:latest
# Yalnız AI_MOTOR=gemini iken gerekir.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
ONERI_CALISMA_GUNU=0
ONERI_CALISMA_SAATI=6
# Son Uyarılar akışı: son N saatlik ham veriye bakıp yoğun hatlar için anlık LLM uyarısı.
UYARI_SAAT_PENCERE=3
UYARI_CALISMA_PERIYODU_SN=10800
